# ===================================================
# Database (AWS RDS MySQL)
# ===================================================
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PWD=your_password
DB_NAME=jcc_dmc

# ===================================================
# Auth
# ===================================================
JWT_SECRET=your_jwt_secret_change_this_in_production

# ===================================================
# VPC (배포 시 필수. sls offline 로컬 실행 시에는 무시됨)
# ===================================================
VPC_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
VPC_SUBNET_ID_1=subnet-xxxxxxxxxxxxxxxxx
VPC_SUBNET_ID_2=subnet-xxxxxxxxxxxxxxxxx

# ===================================================
# AWS Profile (deploy/remove 시 사용)
# ===================================================
AWS_DEPLOY_PROFILE=serverless-deployer
